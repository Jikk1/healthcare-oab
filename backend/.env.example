# ============================================================
# HealthCareOAB+ backend — environment configuration
# Copy to `.env` and adjust. NEVER commit a real .env.
# ============================================================

# --- Runtime ---
NODE_ENV=development
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=debug
SERVICE_NAME=healthcare-oab-api
SERVICE_VERSION=1.0.0

# --- Public origins (CORS, cookie domain) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://127.0.0.1:5500
COOKIE_DOMAIN=localhost

# --- PostgreSQL (Prisma) ---
DATABASE_URL=postgresql://oab:oab_dev_password@localhost:5432/healthcare_oab?schema=public

# --- Redis (sessions, rate-limit, cache) ---
REDIS_URL=redis://localhost:6379

# --- JWT / auth secrets (rotate via KMS/Vault in prod) ---
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=dev-access-secret-change-me-please-32-bytes-min
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-please-32-bytes-min
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
JWT_ISSUER=healthcare-oab
JWT_AUDIENCE=healthcare-oab-clients

# --- Password hashing (argon2id) ---
ARGON_MEMORY_COST=19456
ARGON_TIME_COST=2
ARGON_PARALLELISM=1

# --- Field-level encryption key (AES-256-GCM, 32 bytes base64) for PHI ---
PHI_ENCRYPTION_KEY=ZGV2LXBoaS1lbmNyeXB0aW9uLWtleS0zMmJ5dGVzLXh4eHg=

# --- MFA ---
MFA_ISSUER=HealthCareOAB+

# --- Rate limiting (global default) ---
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=60000

# --- Observability ---
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
METRICS_ENABLED=true

# --- Feature flags ---
FEATURE_MFA=true
FEATURE_BILLING=true
